# Core Environment Variables
export EDITOR="hx"
export VISUAL="hx"
export LANG=en_US.UTF-8

# Bootstrap Antidote Plugin Manager
ANTIDOTE_DIR="$HOME/.local/share/antidote"
if [ ! -d "$ANTIDOTE_DIR" ]; then
    mkdir -p "${ANTIDOTE_DIR%/*}"
    git clone --depth=1 https://github.com/mattmc3/antidote.git "$ANTIDOTE_DIR"
fi
source "$ANTIDOTE_DIR/antidote.zsh"

# Statically compile and load plugins
antidote load

# Muscle Memory Translation Layer (Aliases)
alias cat="bat --style=plain"
alias ls="eza --icons --group-directories-first"
alias ll="eza -la --icons --group-directories-first"
alias find="fd"
alias grep="rg"

# Initialize Tools
eval "$(starship init zsh)"

# Setup fzf integrations if available
[ -f /usr/share/fzf/shell/key-bindings.zsh ] && source /usr/share/fzf/shell/key-bindings.zsh
[ -f /usr/share/fzf/shell/completion.zsh ] && source /usr/share/fzf/shell/completion.zsh

# Activate mise if available
command -v mise >/dev/null && eval "$(mise activate zsh)"
